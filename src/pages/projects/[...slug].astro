---
import BaseLayout from '../../layouts/BaseLayout.astro';
import GitHubIcon from '../../components/GitHubIcon.astro';
import Tags from '../../components/Tags.astro';
import { getCollection, render } from 'astro:content';
import type { GetStaticPathsItem } from 'astro';

export function getStaticPaths(): Promise<GetStaticPathsItem[]> {
  const projects = getCollection('projects');
  return projects.then((projects) =>
    projects.map((project) => ({
      params: { slug: project.id },
      props: { project },
    })),
  );
}

const { project } = Astro.props;
const { title, description, tags, repoUrl, demoUrl, imageUrl } = project.data;
const { Content } = await render(project);
---

<BaseLayout title={`${title} - Francesco Bozzo`} description={description}>
  <article class="project-detail">
    <header class="project-header">
      {imageUrl && (
        <div class="project-image">
          <img src={imageUrl} alt={title} loading="lazy" />
        </div>
      )}
      <h1>{title}</h1>
      <p class="project-description">{description}</p>
      <div class="project-meta">
        {tags.length > 0 && <Tags tags={tags} size="md" />}
        <div class="project-links">
          {repoUrl && (
            <a href={repoUrl} target="_blank" rel="noopener noreferrer" class="project-link">
              <GitHubIcon size={16} />
              <span>Repository</span>
            </a>
          )}
          {demoUrl && (
            <a href={demoUrl} target="_blank" rel="noopener noreferrer" class="project-link">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path><polyline points="15 3 21 3 21 9"></polyline><line x1="10" y1="14" x2="21" y2="3"></line></svg>
              <span>Live Demo</span>
            </a>
          )}
        </div>
      </div>
    </header>

    <div class="project-content">
      <Content />
    </div>

    <nav class="project-nav">
      <a href="/projects" class="back-link">&larr; All Projects</a>
    </nav>
  </article>
</BaseLayout>

<style>
  .project-detail {
    max-width: var(--content-max);
  }

  .project-header {
    margin-bottom: 2rem;
  }

  .project-header h1 {
    margin-top: 0;
    margin-bottom: 0.3em;
  }

  .project-image {
    width: 100%;
    margin-bottom: 1.5rem;
  }

  .project-image img {
    width: 100%;
    height: auto;
    border-radius: 8px;
  }

  .project-description {
    font-size: 1.05rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin-bottom: 0.75em;
  }

  .project-meta {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    flex-wrap: wrap;
    justify-content: space-between;
  }

  .project-links {
    display: flex;
    gap: 0.75rem;
  }

  .project-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35em;
    font-family: var(--font-sans);
    font-size: 0.85rem;
    color: var(--color-accent);
    text-decoration: none;
    padding: 0.25em 0.6em;
    border: 1px solid var(--color-accent);
    border-radius: 6px;
    transition: background var(--transition-fast), color var(--transition-fast);
  }

  .project-link:hover {
    background: var(--color-accent);
    color: #ffffff;
    text-decoration: none;
  }

  .project-content {
    margin-bottom: 2rem;
  }

  .project-content h2,
  .project-content h3,
  .project-content h4 {
    margin-top: 2em;
  }

  .project-content p {
    margin-bottom: 1.25em;
  }

  .project-content table {
    font-size: 0.9em;
  }

  .project-content table th {
    font-family: var(--font-sans);
  }

  .project-nav {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }

  .back-link {
    font-family: var(--font-sans);
    font-size: 0.9rem;
    color: var(--color-accent);
    text-decoration: none;
  }

  .back-link:hover {
    text-decoration: underline;
  }
</style>
