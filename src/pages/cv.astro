---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="CV — Francesco Bozzo" description="Curriculum Vitae of Francesco Bozzo">
  <h1>CV</h1>

  <p>
    <a href="/cv.pdf" download class="download-link">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
      Download PDF
    </a>
  </p>

  <section>
    <h2>Experience</h2>
    <div class="cv-entry">
      <div class="cv-header">
        <strong>Job Title</strong>
        <span class="cv-company">Company Name</span>
      </div>
      <time class="cv-date">2023 — Present</time>
      <p>Lorem ipsum dolor sit amet, consectetur adipiscing elit.</p>
    </div>
    <div class="cv-entry">
      <div class="cv-header">
        <strong>Previous Role</strong>
        <span class="cv-company">Previous Company</span>
      </div>
      <time class="cv-date">2020 — 2023</time>
      <p>Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua.</p>
    </div>
  </section>

  <section>
    <h2>Education</h2>
    <div class="cv-entry">
      <div class="cv-header">
        <strong>Degree</strong>
        <span class="cv-company">University</span>
      </div>
      <time class="cv-date">2016 — 2020</time>
    </div>
  </section>

  <section>
    <h2>Skills</h2>
    <ul class="skills-list">
      <li>Skill 1</li>
      <li>Skill 2</li>
      <li>Skill 3</li>
    </ul>
  </section>
</BaseLayout>

<style>
  .download-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4em;
    font-family: var(--font-sans);
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-accent);
    text-decoration: none;
    padding: 0.4em 0.8em;
    border: 1px solid var(--color-accent);
    border-radius: 6px;
    transition: background var(--transition-fast), color var(--transition-fast);
  }

  .download-link:hover {
    background: var(--color-accent);
    color: #ffffff;
    text-decoration: none;
  }

  section {
    margin-top: 2rem;
  }

  .cv-entry {
    margin-bottom: 1.5rem;
    padding-left: 1rem;
    border-left: 2px solid var(--color-border);
  }

  .cv-header {
    display: flex;
    align-items: baseline;
    gap: 0.5em;
    flex-wrap: wrap;
    margin-bottom: 0.15em;
  }

  .cv-company {
    color: var(--color-text-secondary);
    font-size: 0.95em;
  }

  .cv-date {
    font-family: var(--font-sans);
    font-size: 0.8rem;
    color: var(--color-text-muted);
    margin-bottom: 0.3em;
  }

  .skills-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    list-style: none;
    padding: 0;
  }

  .skills-list li {
    font-family: var(--font-sans);
    font-size: 0.85rem;
    padding: 0.2em 0.6em;
    border-radius: 999px;
    background: var(--color-tag-bg);
    color: var(--color-tag-text);
  }
</style>
