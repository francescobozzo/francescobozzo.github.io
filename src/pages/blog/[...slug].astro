---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import type { GetStaticPathsItem } from 'astro';

export function getStaticPaths(): Promise<GetStaticPathsItem[]> {
  const posts = getCollection('blog');
  return posts.then((posts) =>
    posts.map((post) => ({
      params: { slug: post.id },
      props: { post },
    })),
  );
}

const { post } = Astro.props;
const { title, description, pubDate, updatedDate, tags } = post.data;
const { Content } = await render(post);

const readingTime = Math.max(
  1,
  Math.round(post.body.split(/\s+/).length / 200),
);

// Prev/Next navigation
const allPosts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const currentIndex = allPosts.findIndex((p) => p.id === post.id);
const nextPost = currentIndex > 0 ? allPosts[currentIndex - 1] : null;
const prevPost = currentIndex < allPosts.length - 1 ? allPosts[currentIndex + 1] : null;
---

<BaseLayout title={`${title} - Francesco Bozzo`} description={description}>
  <article class="blog-post">
    <header class="post-header">
      <h1>{title}</h1>
      <div class="post-meta">
        <time datetime={pubDate.toISOString()}>
          {pubDate.toLocaleDateString('en-US', {
            year: 'numeric',
            month: 'long',
            day: 'numeric',
          })}
        </time>
        <span class="meta-sep">&middot;</span>
        <span>{readingTime} min read</span>
        {tags.length > 0 && (
          <>
            <span class="meta-sep">&middot;</span>
            <div class="post-tags">
              {tags.map((tag) => (
                <a href={`/blog/tag/${tag}`}>{tag}</a>
              ))}
            </div>
          </>
        )}
      </div>
    </header>

    <div class="post-content">
      <Content />
    </div>

    {updatedDate && (
      <p class="updated-notice">Updated {updatedDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</p>
    )}

    <nav class="post-nav">
      {prevPost && (
        <a href={`/blog/${prevPost.id}`} class="nav-link nav-prev">
          <span class="nav-direction">&larr; Newer</span>
          <span class="nav-title">{prevPost.data.title}</span>
        </a>
      )}
      {nextPost && (
        <a href={`/blog/${nextPost.id}`} class="nav-link nav-next">
          <span class="nav-direction">Older &rarr;</span>
          <span class="nav-title">{nextPost.data.title}</span>
        </a>
      )}
    </nav>
  </article>
</BaseLayout>

<style>
  .blog-post {
    max-width: var(--content-max);
  }

  .post-header {
    margin-bottom: 2rem;
  }

  .post-header h1 {
    margin-top: 0;
    margin-bottom: 0.5em;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.3em;
    flex-wrap: wrap;
    font-family: var(--font-sans);
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  .meta-sep {
    color: var(--color-text-muted);
  }

  .post-tags {
    display: flex;
    gap: 0.3rem;
  }

  .post-tags a {
    font-size: 0.8rem;
    padding: 0.1em 0.45em;
    border-radius: 999px;
    background: var(--color-tag-bg);
    color: var(--color-tag-text);
    text-decoration: none;
    transition: background var(--transition-fast);
  }

  .post-tags a:hover {
    background: var(--color-accent);
    color: #ffffff;
  }

  .post-content {
    margin-bottom: 2rem;
  }

  .post-content h2,
  .post-content h3,
  .post-content h4 {
    margin-top: 2em;
  }

  .post-content p {
    margin-bottom: 1.25em;
  }

  .updated-notice {
    font-family: var(--font-sans);
    font-size: 0.8rem;
    color: var(--color-text-muted);
    font-style: italic;
    margin-bottom: 2rem;
  }

  .post-nav {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1rem;
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }

  .nav-link {
    display: flex;
    flex-direction: column;
    gap: 0.2em;
    padding: 1rem;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    text-decoration: none;
    transition: border-color var(--transition-fast);
  }

  .nav-link:hover {
    border-color: var(--color-accent);
    text-decoration: none;
  }

  .nav-direction {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .nav-title {
    font-family: var(--font-sans);
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--color-accent);
    line-height: 1.3;
  }

  .nav-next {
    text-align: right;
  }
</style>
