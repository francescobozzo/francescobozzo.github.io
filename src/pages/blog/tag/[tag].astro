---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PostCard from '../../../components/PostCard.astro';
import { getCollection } from 'astro:content';
import type { GetStaticPathsItem } from 'astro';

export function getStaticPaths(): Promise<GetStaticPathsItem[]> {
  const posts = getCollection('blog');
  return posts.then((posts) => {
    const tagMap = new Map<string, typeof posts>();
    posts.forEach((post) => {
      post.data.tags.forEach((tag) => {
        const existing = tagMap.get(tag);
        if (existing) {
          existing.push(post);
        } else {
          tagMap.set(tag, [post]);
        }
      });
    });
    return Array.from(tagMap.entries()).map(([tag, taggedPosts]) => ({
      params: { tag },
      props: { tag, posts: taggedPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()) },
    }));
  });
}

const { tag, posts }: { tag: string; posts: typeof import('astro:content').CollectionEntry<'blog'>[] } = Astro.props;
---

<BaseLayout title={`Tag: ${tag} - Francesco Bozzo`} description={`Blog posts tagged with "${tag}"`}>
  <h1>Tag: <span class="tag-label">{tag}</span></h1>
  <p class="post-count">{posts.length} post{posts.length !== 1 ? 's' : ''}</p>
  <a href="/blog" class="back-link">&larr; All posts</a>

  {posts.map((post) => <PostCard post={post} />)}
</BaseLayout>

<style>
  .tag-label {
    color: var(--color-accent);
  }

  .post-count {
    font-family: var(--font-sans);
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin-bottom: 1rem;
  }

  .back-link {
    display: inline-block;
    font-family: var(--font-sans);
    font-size: 0.875rem;
    color: var(--color-accent);
    text-decoration: none;
    margin-bottom: 2rem;
  }

  .back-link:hover {
    text-decoration: underline;
  }
</style>
