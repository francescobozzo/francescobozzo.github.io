---
import ThemeToggle from './ThemeToggle.astro';

interface Props {
  currentPath?: string;
}

const { currentPath = Astro.url.pathname } = Astro.props;

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/blog', label: 'Blog' },
  { href: '/projects', label: 'Projects' },
  { href: '/cv', label: 'CV' },
];
---

<header class="site-header">
  <div class="header-inner">
    <a href="/" class="site-title">francescobozzo</a>

    <button
      class="nav-toggle"
      aria-label="Toggle navigation"
      aria-expanded="false"
      type="button"
    >
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
    </button>

    <ThemeToggle />
    <nav class="nav-links">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class:list={['nav-link', { active: currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href)) }]}
        >
          {link.label}
        </a>
      ))}
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    width: 100%;
    height: var(--header-height);
    border-bottom: 1px solid var(--color-border);
    transition: border-color var(--transition-normal);
  }

  .header-inner {
    max-width: 72ch;
    margin: 0 auto;
    padding: 0 var(--page-padding);
    height: 100%;
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .site-title {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 1.1rem;
    color: var(--color-text);
    text-decoration: none;
    letter-spacing: -0.02em;
    white-space: nowrap;
    transition: color var(--transition-fast);
  }

  .site-title:hover {
    color: var(--color-accent);
    text-decoration: none;
  }

  /* Hamburger — hidden on desktop */
  .nav-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    width: 36px;
    height: 36px;
    border: none;
    border-radius: 6px;
    background: transparent;
    cursor: pointer;
    gap: 5px;
    padding: 0;
  }

  .nav-toggle:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .hamburger-line {
    display: block;
    width: 20px;
    height: 2px;
    background: var(--color-text);
    border-radius: 2px;
    transition: transform var(--transition-fast), opacity var(--transition-fast);
  }

  /* Hamburger active state */
  .nav-toggle[aria-expanded='true'] .hamburger-line:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .nav-toggle[aria-expanded='true'] .hamburger-line:nth-child(2) {
    opacity: 0;
  }
  .nav-toggle[aria-expanded='true'] .hamburger-line:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    margin-left: auto;
  }

  .nav-link {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text-secondary);
    text-decoration: none;
    padding: 0.35em 0.6em;
    border-radius: 4px;
    transition: color var(--transition-fast), background var(--transition-fast);
    white-space: nowrap;
  }

  .nav-link:hover {
    color: var(--color-text);
    text-decoration: none;
  }

  .nav-link.active {
    color: var(--color-accent);
  }

  /* Mobile: hamburger nav */
  @media (max-width: 640px) {
    .nav-toggle {
      display: flex;
      margin-left: auto;
    }

    .header-inner {
      gap: 0.5rem;
    }

    .nav-links {
      position: fixed;
      top: var(--header-height);
      left: 0;
      right: 0;
      bottom: 0;
      flex-direction: column;
      align-items: stretch;
      padding: 0.5rem var(--page-padding);
      gap: 0;
      border-top: 1px solid var(--color-border);
      overflow-y: auto;
      z-index: 99;
      visibility: hidden;
      opacity: 0;
    }

    .nav-links.open {
      visibility: visible;
      opacity: 1;
    }

    .nav-link {
      font-size: 0.95rem;
      padding: 0.5em 0.5em;
      border-radius: 0;
      border-bottom: 1px solid var(--color-border);
    }


  }
</style>

<script is:inline>
  // Mobile nav toggle — event delegation survives ClientRouter swaps
  document.addEventListener('click', (e) => {
    var toggle = e.target.closest('.nav-toggle');
    if (!toggle) return;
    var nav = document.querySelector('.nav-links');
    var isOpen = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!isOpen));
    nav?.classList.toggle('open');
    // Lock scroll on html when nav open
    document.documentElement.style.overflow = isOpen ? '' : 'hidden';
  });

  // Close on escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      var nav = document.querySelector('.nav-links');
      if (nav?.classList.contains('open')) {
        var toggle = document.querySelector('.nav-toggle');
        toggle?.setAttribute('aria-expanded', 'false');
        nav?.classList.remove('open');
        toggle?.focus();
        document.documentElement.style.overflow = '';
      }
    }
  });

  // Close on ClientRouter navigation — menu stays open during swap, hiding old page
  document.addEventListener('astro:after-swap', () => {
    var nav = document.querySelector('.nav-links');
    var toggle = document.querySelector('.nav-toggle');
    toggle?.setAttribute('aria-expanded', 'false');
    nav?.classList.remove('open');
    document.documentElement.style.overflow = '';
  });
</script>
