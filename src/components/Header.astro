---
import ThemeToggle from './ThemeToggle.astro';

interface Props {
  currentPath?: string;
}

const { currentPath = Astro.url.pathname } = Astro.props;

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/blog', label: 'Blog' },
  { href: '/projects', label: 'Projects' },
];
---

<header class="site-header">
  <div class="header-inner">
    <a href="/" class="site-title">francesco.bozzo</a>

    <button
      class="nav-toggle"
      aria-label="Toggle navigation"
      aria-expanded="false"
      type="button"
    >
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
    </button>

    <nav class="nav-links">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class:list={['nav-link', { active: currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href)) }]}
        >
          {link.label}
        </a>
      ))}
    </nav>
    <ThemeToggle />
  </div>
</header>

<style>
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    z-index: 100;
    width: 100%;
    height: var(--header-height);
    border-bottom: 1px solid var(--color-border);
    transition: border-color var(--transition-normal);
  }

  .header-inner {
    max-width: min(calc(var(--content-max) + var(--page-padding) * 2), 100%);
    margin: 0 auto;
    padding: 0 var(--page-padding);
    height: 100%;
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .site-title {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 1.1rem;
    color: var(--color-text);
    text-decoration: none;
    letter-spacing: -0.02em;
    white-space: nowrap;
    transition: color var(--transition-fast);
  }

  .site-title:hover {
    color: var(--color-accent);
    text-decoration: none;
  }

  /* Hamburger - hidden on desktop */
  .nav-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    width: 36px;
    height: 36px;
    border: none;
    border-radius: 6px;
    background: transparent;
    cursor: pointer;
    gap: 5px;
    padding: 0;
    -webkit-user-select: none;
    user-select: none;
    -webkit-tap-highlight-color: transparent;
    touch-action: none;
  }

  .nav-toggle:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .hamburger-line {
    display: block;
    width: 20px;
    height: 2px;
    background: var(--color-text);
    border-radius: 2px;
    transition: transform var(--transition-fast);
    -webkit-user-select: none;
    user-select: none;
    -webkit-touch-callout: none;
  }

  /* Hamburger active state */
  .nav-toggle[aria-expanded='true'] .hamburger-line:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .nav-toggle[aria-expanded='true'] .hamburger-line:nth-child(2) {
    opacity: 0;
    transition: none;
  }
  .nav-toggle[aria-expanded='true'] .hamburger-line:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    margin-left: auto;
    margin-right: 1rem;
  }

  .nav-link {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text-secondary);
    text-decoration: none;
    padding: 0.35em 0.6em;
    border-radius: 4px;
    transition: color var(--transition-fast), background var(--transition-fast);
    white-space: nowrap;
  }

  .nav-link:hover {
    color: var(--color-text);
    text-decoration: none;
  }

  .nav-link.active {
    color: var(--color-accent);
  }

  /* Mobile: hamburger nav */
  @media (max-width: 640px) {
    .nav-toggle {
      display: flex;
      margin-left: auto;
    }

    .header-inner {
      gap: 0.5rem;
    }

    .nav-links {
      position: fixed;
      top: var(--header-height);
      left: 0;
      right: 0;
      bottom: 0;
      flex-direction: column;
      align-items: stretch;
      padding: 0.5rem var(--page-padding);
      gap: 0;
      border-top: 1px solid var(--color-border);
      overflow-y: auto;
      z-index: 99;
      visibility: hidden;
      opacity: 0;
    }

    .nav-links.open {
      visibility: visible;
      opacity: 1;
    }

    .nav-link {
      font-size: 0.95rem;
      padding: 0.5em 0.5em;
      border-radius: 0;
      border-bottom: 1px solid var(--color-border);
    }


  }
</style>

<script is:inline>
  (function () {
    var prefetched = new Set();

    function getToggle() { return document.querySelector('.nav-toggle'); }
    function getNav() { return document.querySelector('.nav-links'); }

    function toggleNav() {
      var toggle = getToggle();
      var nav = getNav();
      if (!toggle || !nav) return;

      var isOpen = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', String(!isOpen));
      nav.classList.toggle('open');
      document.documentElement.style.overflow = isOpen ? '' : 'hidden';
      // Prefetch nav pages when menu opens (hidden links skip Astro's IntersectionObserver)
      if (!isOpen) {
        nav.querySelectorAll('a[href]').forEach(function (link) {
          var href = link.getAttribute('href');
          if (href && !href.startsWith('#') && !href.startsWith('http') && !prefetched.has(href)) {
            prefetched.add(href);
            var linkEl = document.createElement('link');
            linkEl.rel = 'prefetch';
            linkEl.href = href;
            linkEl.as = 'document';
            document.head.appendChild(linkEl);
          }
        });
      }
    }

    // Delegation - survives ClientRouter swaps
    document.addEventListener('click', function (e) {
      if (e.target.closest('.nav-toggle')) {
        toggleNav();
      }
    });

    // Close on escape
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape') {
        var nav = getNav();
        var toggle = getToggle();
        if (nav?.classList.contains('open')) {
          toggle.setAttribute('aria-expanded', 'false');
          nav.classList.remove('open');
          toggle?.focus();
          document.documentElement.style.overflow = '';
        }
      }
    });

    // Close menu after ClientRouter navigation
    document.addEventListener('astro:after-swap', function () {
      var nav = getNav();
      var toggle = getToggle();
      if (nav?.classList.contains('open')) {
        toggle.setAttribute('aria-expanded', 'false');
        nav.classList.remove('open');
        document.documentElement.style.overflow = '';
      }
    });
  })();
</script>
