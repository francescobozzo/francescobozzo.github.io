---
import ThemeToggle from './ThemeToggle.astro';

interface Props {
  currentPath?: string;
}

const { currentPath = Astro.url.pathname } = Astro.props;

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/blog', label: 'Blog' },
  { href: '/projects', label: 'Projects' },
];
---

<header class="site-header">
  <div class="header-inner">
    <a href="/" class="site-title">francescobozzo</a>

    <button
      class="nav-toggle"
      aria-label="Toggle navigation"
      aria-expanded="false"
      type="button"
    >
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
    </button>

    <ThemeToggle />
    <nav class="nav-links">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class:list={['nav-link', { active: currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href)) }]}
        >
          {link.label}
        </a>
      ))}
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    width: 100%;
    height: var(--header-height);
    border-bottom: 1px solid var(--color-border);
    transition: border-color var(--transition-normal);
  }

  .header-inner {
    max-width: 72ch;
    margin: 0 auto;
    padding: 0 var(--page-padding);
    height: 100%;
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .site-title {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 1.1rem;
    color: var(--color-text);
    text-decoration: none;
    letter-spacing: -0.02em;
    white-space: nowrap;
    transition: color var(--transition-fast);
  }

  .site-title:hover {
    color: var(--color-accent);
    text-decoration: none;
  }

  /* Hamburger — hidden on desktop */
  .nav-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    width: 36px;
    height: 36px;
    border: none;
    border-radius: 6px;
    background: transparent;
    cursor: pointer;
    gap: 5px;
    padding: 0;
    -webkit-user-select: none;
    user-select: none;
    -webkit-tap-highlight-color: transparent;
    touch-action: manipulation;
  }

  .nav-toggle:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .hamburger-line {
    display: block;
    width: 20px;
    height: 2px;
    background: var(--color-text);
    border-radius: 2px;
    transition: transform var(--transition-fast);
    -webkit-user-select: none;
    user-select: none;
    -webkit-touch-callout: none;
  }

  /* Hamburger active state */
  .nav-toggle[aria-expanded='true'] .hamburger-line:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .nav-toggle[aria-expanded='true'] .hamburger-line:nth-child(2) {
    opacity: 0;
    transition: none;
  }
  .nav-toggle[aria-expanded='true'] .hamburger-line:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    margin-left: auto;
  }

  .nav-link {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text-secondary);
    text-decoration: none;
    padding: 0.35em 0.6em;
    border-radius: 4px;
    transition: color var(--transition-fast), background var(--transition-fast);
    white-space: nowrap;
  }

  .nav-link:hover {
    color: var(--color-text);
    text-decoration: none;
  }

  .nav-link.active {
    color: var(--color-accent);
  }

  /* Mobile: hamburger nav */
  @media (max-width: 640px) {
    .nav-toggle {
      display: flex;
      margin-left: auto;
    }

    .header-inner {
      gap: 0.5rem;
    }

    .nav-links {
      position: fixed;
      top: var(--header-height);
      left: 0;
      right: 0;
      bottom: 0;
      flex-direction: column;
      align-items: stretch;
      padding: 0.5rem var(--page-padding);
      gap: 0;
      border-top: 1px solid var(--color-border);
      overflow-y: auto;
      z-index: 99;
      visibility: hidden;
      opacity: 0;
    }

    .nav-links.open {
      visibility: visible;
      opacity: 1;
    }

    .nav-link {
      font-size: 0.95rem;
      padding: 0.5em 0.5em;
      border-radius: 0;
      border-bottom: 1px solid var(--color-border);
    }


  }
</style>

<script is:inline>
  (function () {
    var toggle = document.querySelector('.nav-toggle');
    var nav = document.querySelector('.nav-links');
    if (!toggle || !nav) return;

    var toggled = false;
    function toggleNav() {
      if (toggled) return;
      toggled = true;
      setTimeout(function () { toggled = false; }, 300);

      var isOpen = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', String(!isOpen));
      nav.classList.toggle('open');
      document.documentElement.style.overflow = isOpen ? '' : 'hidden';
      // Prefetch nav pages when menu opens (hidden links skip Astro's IntersectionObserver)
      if (!isOpen) {
        requestAnimationFrame(function () {
          nav.querySelectorAll('a[href]').forEach(function (link) {
            var href = link.getAttribute('href');
            if (href && !href.startsWith('#') && !href.startsWith('http')) {
              var linkEl = document.createElement('link');
              linkEl.rel = 'prefetch';
              linkEl.href = href;
              linkEl.as = 'document';
              document.head.appendChild(linkEl);
            }
          });
        });
      }
    }

    toggle.addEventListener('touchend', function (e) {
      e.preventDefault();
      e.stopPropagation();
      toggleNav();
    });
    toggle.addEventListener('click', toggleNav);

    // Close on escape
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && nav.classList.contains('open')) {
        toggle.setAttribute('aria-expanded', 'false');
        nav.classList.remove('open');
        toggle.focus();
        document.documentElement.style.overflow = '';
      }
    });

    // Close menu after ClientRouter navigation
    document.addEventListener('astro:after-swap', function () {
      if (nav.classList.contains('open')) {
        toggle.setAttribute('aria-expanded', 'false');
        nav.classList.remove('open');
        document.documentElement.style.overflow = '';
      }
    });
  })();
</script>
