---
import type { CollectionEntry } from 'astro:content';
import { readingTime } from '../lib/readingTime';
import { formatDateCompact } from '../lib/formatDate';
import Tags from './Tags.astro';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, pubDate, tags } = post.data;

const minutes = readingTime(post.body);
---

<article class="post-card">
  <h2 class="post-title">
    <a href={`/blog/${post.id}`}>{title}</a>
  </h2>
  <div class="post-meta">
    <time datetime={pubDate.toISOString()}>
      {formatDateCompact(pubDate)}
    </time>
    <span class="meta-sep">&middot;</span>
    <span class="reading-time">{minutes} min read</span>
    {tags.length > 0 && (
      <>
        <span class="meta-sep">&middot;</span>
        <Tags tags={tags} link size="sm" />
      </>
    )}
  </div>
  <p class="post-excerpt">{description}</p>
  <a href={`/blog/${post.id}`} class="read-more">Read more &rarr;</a>
</article>

<style>
  .post-card {
    margin-bottom: 2rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--color-border);
  }

  .post-card:last-child {
    border-bottom: none;
  }

  .post-title {
    font-size: 1.3rem;
    margin: 0 0 0.4em;
  }

  .post-title a {
    color: var(--color-text);
    text-decoration: none;
  }

  .post-title a:hover {
    color: var(--color-accent);
    text-decoration: underline;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.3em;
    flex-wrap: wrap;
    font-family: var(--font-sans);
    font-size: 0.8rem;
    color: var(--color-text-muted);
    margin-bottom: 0.5em;
  }

  .meta-sep {
    color: var(--color-text-muted);
  }

  .post-excerpt {
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin-bottom: 0.5em;
  }

  .read-more {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-accent);
    text-decoration: none;
  }

  .read-more:hover {
    text-decoration: underline;
  }
</style>
