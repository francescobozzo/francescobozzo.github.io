---
interface Props {
  diagram: string;
}

const { diagram } = Astro.props;
---

<div class="mermaid-wrapper">
  <div class="mermaid">
    <pre class="mermaid-source" hidden>{diagram}</pre>
  </div>
</div>

<style>
  .mermaid-wrapper {
    margin: 1.5em 0;
    text-align: center;
    background: var(--color-bg-secondary, #f8f9fa);
    border: 1px solid var(--color-border, #d0d7de);
    border-radius: 8px;
    padding: 0.75rem 1rem;
    overflow-x: auto;
  }

  .mermaid {
    line-height: 0;
  }

  .mermaid svg {
    max-width: 100%;
    height: auto;
    display: block;
  }

  .mermaid-error {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--color-text-muted);
    text-align: left;
    padding: 0.5rem;
    margin: 0;
    white-space: pre;
  }
</style>

<script>
import mermaid from 'mermaid';

function getTheme() {
  return document.documentElement.getAttribute('data-theme') === 'dark' ? 'dark' : 'default';
}

function initMermaid() {
  mermaid.initialize({
    startOnLoad: false,
    theme: getTheme(),
    securityLevel: 'sandbox',
    // Respect user's motion preference
    ...(window.matchMedia('(prefers-reduced-motion: reduce)').matches
      ? { sequence: false }
      : {}),
  });
}

function renderAll() {
  const elements = document.querySelectorAll('.mermaid');
  elements.forEach((el) => {
    const source = el.querySelector('.mermaid-source');
    if (!source) return;
    const diagram = source.textContent || '';
    if (!diagram.trim()) return;

    // Clear previous content (SVG or error)
    el.innerHTML = '';

    const id = `mermaid-${Math.random().toString(36).slice(2, 10)}`;
    mermaid.render(id, diagram).then((result) => {
      el.innerHTML = result.svg;
    }).catch((err) => {
      console.error('Mermaid render error:', err);
      el.innerHTML = `<pre class="mermaid-error">${diagram}</pre>`;
    });
  });
}

initMermaid();
renderAll();

// Re-render on theme change
document.addEventListener('astro:after-swap', () => {
  initMermaid();
  renderAll();
});
</script>
