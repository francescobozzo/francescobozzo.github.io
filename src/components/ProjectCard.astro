---
import type { CollectionEntry } from 'astro:content';
import GitHubIcon from './GitHubIcon.astro';

interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
const { title, description, tags, demoUrl, repoUrl, imageUrl } = project.data;

const detailUrl = `/projects/${project.id}`;
---

<article class="project-card">
  {imageUrl && (
    <div class="project-image">
      <img src={imageUrl} alt={title} loading="lazy" />
    </div>
  )}
  <div class="project-body">
    <h3 class="project-title">
      <a href={detailUrl}>{title}</a>
    </h3>
    <p class="project-description">{description}</p>
    <div class="project-meta">
      {tags.length > 0 && (
        <div class="project-tags">
          {tags.map((tag) => <span class="tag">{tag}</span>)}
        </div>
      )}
      <div class="project-links">
        {repoUrl && (
          <a href={repoUrl} target="_blank" rel="noopener" aria-label="Repository">
            <GitHubIcon size={16} />
          </a>
        )}
        {demoUrl && (
          <a href={demoUrl} target="_blank" rel="noopener" aria-label="Live demo">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path><polyline points="15 3 21 3 21 9"></polyline><line x1="10" y1="14" x2="21" y2="3"></line></svg>
          </a>
        )}
      </div>
    </div>

  </div>
</article>

<style>
  .project-card {
    display: flex;
    flex-direction: column;
    padding: 0;
    border: 1px solid var(--color-card-border);
    border-radius: 8px;
    background: var(--color-card-bg);
    transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
    overflow: hidden;
  }

  .project-card:hover {
    border-color: var(--color-card-hover-border);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
  }

  .project-image {
    width: 100%;
    max-height: 200px;
    overflow: hidden;
  }

  .project-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .project-body {
    padding: 1.25rem;
    flex: 1;
  }

  .project-title {
    font-family: var(--font-sans);
    font-size: 1.1rem;
    font-weight: 600;
    margin: 0 0 0.4em;
  }

  .project-title a {
    color: var(--color-text);
    text-decoration: none;
  }

  .project-title a:hover {
    color: var(--color-accent);
    text-decoration: underline;
  }

  .project-description {
    font-size: 0.925rem;
    color: var(--color-text-secondary);
    line-height: 1.5;
    margin-bottom: 0.75em;
  }

  .project-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .project-tags {
    display: flex;
    gap: 0.35rem;
    flex-wrap: wrap;
  }

  .tag {
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: 500;
    padding: 0.15em 0.5em;
    border-radius: 999px;
    background: var(--color-tag-bg);
    color: var(--color-tag-text);
  }

  .project-links {
    display: flex;
    gap: 0.5rem;
  }

  .project-links a {
    color: var(--color-text-muted);
    transition: color var(--transition-fast);
  }

  .project-links a:hover {
    color: var(--color-accent);
  }


</style>
