---
import '../styles/global.css';
import '../styles/katex.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Personal website of Francesco Bozzo' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <!-- Set theme before CSS loads — prevents flash -->
    <script is:inline>
      (function(){
        var t = localStorage.getItem('theme');
        if (!t) t = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        document.documentElement.setAttribute('data-theme', t);
      })();
    </script>

    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content="Francesco Bozzo" />

    <title>{title}</title>

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- RSS auto-discovery -->
    <link
      rel="alternate"
      type="application/rss+xml"
      title="Francesco Bozzo — Blog RSS"
      href="/rss.xml"
    />

    <!-- Client-side navigation (instant page swaps, no animation to prevent flash) -->
    <ClientRouter transition="none" />

    <slot name="head" />
  </head>
  <body>
        <script is:inline>
      (function(){
        // Disable browser's built-in scroll restoration
        history.scrollRestoration='manual';

        var p=location.pathname;
        function k(){return '__s:'+p}

        // Debounced scroll saver — captures final position even during momentum
        var scrollTimer;
        function saveScroll(){
          var y=window.scrollY;
          sessionStorage.setItem(k(), y);
        }
        window.addEventListener('scroll',function(){
          clearTimeout(scrollTimer);
          scrollTimer=setTimeout(saveScroll,100);
        },{passive:true});

        // Save on navigation start (catches position before momentum settles)
        document.addEventListener('astro:before-preparation',function(){
          saveScroll();
        });

        // Save on unload
        window.addEventListener('beforeunload',function(){saveScroll()});

        // Set inline bg colors BEFORE swap — modifies new document before it enters DOM
        document.addEventListener('astro:before-swap',function(e){
          var t=localStorage.getItem('theme');
          var isDark=t?t==='dark':window.matchMedia('(prefers-color-scheme: dark)').matches;
          var codeBg=isDark?'#24292e':'#f6f8fa';
          var headerBg=isDark?'#0d1117':'#ffffff';
          var newDoc=e.newDocument;
          newDoc.querySelectorAll('.astro-code').forEach(function(el){
            el.style.backgroundColor=codeBg;
          });
          var h=newDoc.querySelector('.site-header');
          if(h)h.style.backgroundColor=headerBg;
        });
        // Clear inline bg styles after page fully loaded — lets CSS handle theme toggles
        document.addEventListener('astro:page-load',function(){
          document.querySelectorAll('.astro-code').forEach(function(el){
            el.style.backgroundColor='';
          });
          var h=document.querySelector('.site-header');
          if(h)h.style.backgroundColor='';
        });
        // Restore scroll after swap
        document.addEventListener('astro:after-swap',function(){
          p=location.pathname;
          var y=sessionStorage.getItem(k());
          if(y!=null) window.scrollTo({top:+y,behavior:'instant'});
        });

      })();
    </script>
    <div class="page-wrapper">
      <Header currentPath={Astro.url.pathname} />
      <main class="content">
        <slot />
      </main>
      <Footer />
    </div>
    <!-- Scroll restoration at end of body — DOM parsed, browser hasn't painted yet -->
    <script is:inline>
      var _y=sessionStorage.getItem('__s:'+location.pathname);
      if(_y!=null)window.scrollTo({top:+_y,behavior:'instant'});
    </script>
  </body>
</html>
